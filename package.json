{
  "name": "praxis-ls",
  "version": "0.1.0",
  "private": true,
  "description": "Praxis LS — white-label, multi-tenant logistics & OHADA-accounting ERP (API + workers).",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20 <21"
  },
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "worker": "node src/jobs/workers.js",
    "dev": "nodemon src/server.js",
    "dev:worker": "nodemon src/jobs/workers.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "jest --runInBand",
    "db:migrate:platform": "node scripts/db/migrate-platform.js",
    "db:provision": "node scripts/db/provision-tenant.js",
    "db:sandbox:wipe": "node scripts/db/sandbox-wipe.js",
    "db:reset:local": "node scripts/db/migrate-platform.js && node scripts/db/provision-tenant.js --slug=smartls --name=\"Smart Logistics\"",
    "setup": "npm install && npm run db:migrate:platform",
    "db:migrate:tenants": "node scripts/db/migrate-tenants.js",
    "platform:create-admin": "node scripts/platform/create-admin.js",
    "tenant:create-admin": "node scripts/tenant/create-admin.js",
    "ai:reindex": "node scripts/ai/reindex.js",
    "ai:reindex:all": "node scripts/ai/reindex.js --all"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "argon2": "^0.41.1",
    "axios": "^1.7.7",
    "bullmq": "^5.28.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "form-data": "^4.0.1",
    "groq-sdk": "^0.9.0",
    "heic-convert": "^2.1.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "maxmind": "^4.3.24",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "openai": "^4.73.0",
    "otplib": "^12.0.1",
    "pg": "^8.13.1",
    "pgvector": "^0.2.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "puppeteer": "^23.9.0",
    "rate-limit-redis": "^4.2.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.15.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.1",
    "supertest": "^7.0.0"
  },
  "//puppeteer": "Chromium is installed by the Docker image (apt) and located via PUPPETEER_EXECUTABLE_PATH; set PUPPETEER_SKIP_DOWNLOAD=1 in CI to avoid the bundled download.",
  "//deepseek": "DeepSeek is OpenAI-API-compatible — the 'openai' SDK is pointed at DEEPSEEK_BASE_URL. Gemini uses @google/generative-ai; Groq uses groq-sdk (voice-to-text)."
}
