# praxis-ls environment template.
#
# Copy to .env and fill in. The values below are tuned for a LOCAL run
# (`npm run dev`): localhost hosts, dev NODE_ENV, fixed dev secrets. For Docker
# (`docker compose up`) you do NOT edit this file — docker-compose.yml overrides
# the host-specific vars (DB_HOST=postgres, REDIS_URL=redis://redis:6379,
# NODE_ENV=production) in its `environment:` block. One .env serves both.
#
# src/config/env.js is the authoritative schema (Zod) with every var + default.
# When in doubt, read that file — not this template.

# ---- Core ----
# Local dev = development (also drives each log line's "env"). Docker sets
# production via compose. Never commit production here.
NODE_ENV=development
APP_BASE_DOMAIN=praxisls.com          # tenants resolve as <tenant>.praxisls.com
APP_NAME=praxisls-backend
PORT=8080

# ---- PostgreSQL (the PLATFORM/registry DB the app boots against) ----
# One DB per tenant is created by provisioning; these are the platform creds.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=praxis_platform
DB_USER=postgres
DB_PASSWORD=changeme                  # match your local Postgres (docker: DB_PASSWORD)
DB_PLATFORM_SCHEMA=platform
# Provisioning uses a superuser to CREATE DATABASE per tenant:
TENANT_DB_SUPERUSER=postgres
TENANT_DB_SUPERUSER_PASSWORD=changeme
DEV_TENANT_SLUG=

# ---- Redis / queue ----
# LOCAL value. Docker overrides this to redis://redis:6379 via compose — do NOT
# put the docker hostname here or `npm run dev` fails with ENOTFOUND redis.
REDIS_URL=redis://localhost:6379

# ---- Auth / crypto ----
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
SESSION_INACTIVITY_MIN=30             # refresh is rejected after this many idle minutes
# AES-256-GCM key for secrets-at-rest (2FA TOTP secrets, vendor keys). MUST be
# 64 hex chars (32 bytes). A fixed dev default is baked into env.js if omitted,
# but generate a real one for anything past a laptop: `openssl rand -hex 32`.
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ---- AI providers (ROTATE the discovery keys before first use) ----
DEEPSEEK_API_KEY=__rotate_me__        # reasoning / agentic assistant (primary)
GEMINI_API_KEY=__rotate_me__          # content + document vision (fallback)
GROQ_API_KEY=__rotate_me__            # voice-to-text
OPENAI_API_KEY=__rotate_me__          # embeddings (pgvector), text-embedding-3-small
AI_MONTHLY_CAP_XAF=0                  # 0 = uncapped; per-feature caps enforced in code

# ---- FX ----
EXCHANGERATE_API_KEY=__rotate_me__    # exchangerate-api, USD base
FX_SYNC_CRON=0 0 * * *                # daily midnight (MOD-08)

# ---- Email / SMTP (per-tenant senders configured in Settings) ----
SMTP_HOST=__host__
SMTP_PORT=587                         # 587 STARTTLS or 465 SSL
SMTP_USER=__user__
SMTP_PASS=__rotate_me__
MAIL_FALLBACK_DOMAIN=nmail.praxisls.com

# ---- Storage (abstracted; local disk now, S3-compatible later) ----
STORAGE_DRIVER=local                  # local | s3
STORAGE_LOCAL_PATH=./data/vault
S3_ENDPOINT=                          # e.g. Hetzner/Backblaze/Wasabi/MinIO (non-AWS)
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ---- PDF ----
# Local: point at your Chromium/Chrome. Docker installs it at /usr/bin/chromium.
PUPPETEER_EXECUTABLE_PATH=
