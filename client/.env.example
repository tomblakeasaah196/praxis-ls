# Client dev config. Copy to .env.local.
#
# The SPA calls /api/* and Vite proxies to the Node API (see vite.config.ts).
VITE_API_TARGET=http://localhost:8080
# The tenant you provisioned — sent as the Host header so the backend resolves
# the tenant locally without editing your hosts file.
VITE_TENANT_HOST=smartls.praxisls.com
# White-label brand colour (any CSS colour). Overrides the default until the
# real per-tenant colour loads from the backend. Try #0f766e, #1d4ed8, #b91c1c…
VITE_BRAND_PRIMARY=#0f766e
